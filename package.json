{
    "name": "quickbooks",
    "label": "Quickbooks",
    "dependencies": [
        {
            "type": "service",
            "name": "http",
            "version": "v1.2.6",
            "instanceId": "shared"
        }
    ],
    "configuration": [
        {
            "label": "Client ID",
            "name": "clientId",
            "type": "text",
            "required": true
        },
        {
            "label": "Client Secret",
            "name": "clientSecret",
            "type": "password",
            "required": true
        },
        {
            "label": "Company ID",
            "name": "companyId",
            "type": "text",
            "required": true
        },
        {
            "label": "Refresh Token",
            "name": "refreshToken",
            "type": "text",
            "required": true
        },
        {
            "label": "QuickBooks Environment",
            "name": "quickbooksEnvironment",
            "type": "buttonsGroup",
            "required": true,
            "defaultValue": "SANDBOX",
            "typeOptions": {
                "allowCustom": true,
                "possibleValues": [
                    {
                        "label": "Sandbox",
                        "name": "sandbox"
                    },
                    {
                        "label": "Production",
                        "name": "production"
                    }
                ]
            }
        },
        {
            "label": "Minor Version",
            "name": "minorVersion",
            "description": "The QuickBooks Online API supports minor versions in order to provide a way for you to access incremental changes without breaking existing apps.",
            "defaultValue": 69,
            "type": "text",
            "typeOptions": {
                "validation": "number"
            }
        },
        {
            "label": "Webhooks Verifier Token",
            "name": "webhooksVerifierToken",
            "type": "text",
            "required": false
        },
        {
            "label": "Webhook URL",
            "name": "webhookUrl",
            "type": "label",
            "value": "@config.WEBHOOK_URL"
        },
        {
            "label": "Quickbooks API URL",
            "name": "quickbooksBaseUrl",
            "type": "label",
            "value": "https://quickbooks.api.intuit.com/v3"
        }
    ],
    "events": [
        {
            "label": "Webhook",
            "name": "webhook",
            "description": "When a webhook arrives from QuickBooks"
        }
    ],
    "metadata": [
        {
            "type": "script",
            "namespace": "api",
            "path": "/scripts/api.js"
        },
        {
            "type": "script",
            "namespace": "utils",
            "path": "/scripts/utils.js"
        }
    ]
}